{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-title-pattern": "chore: release ${component} v${version}",
  "pull-request-header": ":package: Automated release",
  "packages": {
    "packages/nemcss": {
      "release-type": "node",
      "component": "nemcss",
      "tag-prefix": "v"
    },
    "editors/vscode": {
      "release-type": "node",
      "component": "editor",
      "tag-prefix": "editor-v"
    }
  }
}
