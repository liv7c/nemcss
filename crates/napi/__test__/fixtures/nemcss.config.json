{
  "content": ["src/**/*.html"],
  "theme": {
    "colors": {
      "source": "design-tokens/colors.json",
      "prefix": "color",
      "utilities": [
        { "prefix": "text", "property": "color" },
        { "prefix": "bg", "property": "background-color" }
      ]
    },
    "spacing": {
      "source": "design-tokens/spacing.json",
      "prefix": "spacing",
      "utilities": [{ "prefix": "p", "property": "padding" }]
    }
  }
}
