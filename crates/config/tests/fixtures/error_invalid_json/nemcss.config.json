{
  "content": [
    "src/**/*.html",
    "src/**/*.svelte",
  ],
  "tokensDir": "design-tokens",
  "theme": {
    "colors": {
      "prefix": "color",
      "utilities": [
        { "prefix": "text", "property": "color" },
        { "prefix": "bg", "property": "background-color" }
      ]
    },
    "spacing": {
      "utilities": [
        { "prefix": "flow-space", "property": "--flow-space" }
      ]
    }
  }
}

