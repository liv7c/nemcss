{
  "content": [
    "src/**/*.html",
    "src/**/*.svelte"
  ],
  "tokensDir": "design-tokens",
  "theme": {
    "colors": {
      "source": "design-tokens/colors.json",
      "utilities": [
        { "prefix": "highlight", "property": "background-color" }
      ]
    },
    "spacings": {
      "prefix": "spacing",
      "source": "design-tokens/spacings.json",
      "utilities": [
        { "prefix": "pb", "property": "padding-block" }
      ]
    }
  }
}

